{
  "manifest_version": 3,
  "name": "React Profiler Bridge",
  "description": "Real React DevTools profiling pipeline for headless Playwright automation",
  "version": "3.0.0",
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "backend.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "proxy.js"
      ],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ],
  "background": {
    "service_worker": "frontend.js"
  }
}
